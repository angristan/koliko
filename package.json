{
  "name": "koliko",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.9",
  "type": "module",
  "description": "Privacy-first usage analytics for coding agents",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/angristan/koliko.git"
  },
  "bugs": {
    "url": "https://github.com/angristan/koliko/issues"
  },
  "keywords": ["pi-package", "analytics", "cloudflare", "coding-agent"],
  "scripts": {
    "build": "vite build",
    "build:production": "KOLIKO_WRANGLER_CONFIG=wrangler.production.jsonc vite build",
    "verify": "bun run cf:typecheck && bun run typecheck && bun run test && bun run build && wrangler deploy --dry-run",
    "dev": "vite --host localhost --port 8787 --strictPort",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "cf:typegen": "wrangler types --env-file .dev.vars.example",
    "cf:typecheck": "wrangler types --env-file .dev.vars.example --check",
    "prepare:production-config": "bun scripts/prepare-production-config.ts",
    "smoke:production": "bun scripts/smoke-production.ts",
    "db:migrate:local": "wrangler d1 migrations apply koliko --local",
    "db:seed:local": "bun scripts/seed-local.ts",
    "db:migrate:remote": "bun run prepare:production-config && wrangler d1 migrations apply koliko --remote --config wrangler.production.jsonc",
    "deploy:dry-run": "bun run prepare:production-config && bun run build:production && wrangler deploy --dry-run",
    "deploy": "bun run prepare:production-config && bun run verify && bun run build:production && wrangler d1 migrations apply koliko --remote --config wrangler.production.jsonc && wrangler deploy && bun run smoke:production"
  },
  "pi": {
    "extensions": [
      "./collectors/pi/index.ts"
    ]
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.3.0",
    "@mantine/charts": "9.4.2",
    "@mantine/core": "^9.4.2",
    "@mantine/hooks": "^9.4.2",
    "@phosphor-icons/react": "^2.1.10",
    "@simplewebauthn/browser": "13.3.0",
    "@simplewebauthn/server": "13.3.0",
    "@tanstack/react-query": "^5.101.4",
    "effect": "4.0.0-beta.99",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "recharts": "^3.10.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.46.0",
    "@cloudflare/vitest-pool-workers": "0.18.7",
    "@earendil-works/pi-coding-agent": "0.81.1",
    "@effect/vitest": "4.0.0-beta.99",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.0",
    "wrangler": "4.113.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
